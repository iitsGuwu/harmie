# Harmies Arena — Environment Variables
# Copy this file to .env and fill in your values

# Helius DAS API Key (server-only in local dev via Vite proxy)
HELIUS_API_KEY=your_helius_api_key_here

# Netlify only: optional extra origins for /api/helius and /api/magiceden (comma-separated).
# Production and deploy-preview URLs are detected automatically (URL, DEPLOY_PRIME_URL).
# If the live site uses a custom domain, add it here or requests to /api/* may be blocked (403).
# ALLOWED_ORIGINS=https://www.your-custom-domain.com
#
# Helius 401: set HELIUS_API_KEY in Netlify to a valid mainnet key from https://dashboard.helius.dev
#
# Supabase auth 422 on anonymous signup: Dashboard → Authentication → Providers → enable Anonymous.

# Supabase (get from your Supabase project dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key_here

# GitHub Repository URL
VITE_GITHUB_URL=https://github.com/your-username/harmies

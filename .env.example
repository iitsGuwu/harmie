# Harmies Arena — Environment Variables
# Copy this file to .env and fill in your values

# Helius DAS API Key (server-only in local dev via Vite proxy)
HELIUS_API_KEY=your_helius_api_key_here

# Supabase (get from your Supabase project dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key_here

# GitHub Repository URL
VITE_GITHUB_URL=https://github.com/your-username/harmies
